---
import BaseLayout from "./BaseLayout.astro";
import SlideDrawer from "../components/SlideDrawer.astro";

interface Props {
  title: string;
  slides?: Array<{ id: string; title: string; part: number; slideNumber: number }>;
}

const { title, slides = [] } = Astro.props;
---

<BaseLayout title={title}>
  <main class="bg-bg-primary text-text-primary">
    <slot />
  </main>

  {slides.length > 0 && <SlideDrawer slides={slides} />}

  <!-- Mermaid diagram rendering -->
  <script>
    import mermaid from 'mermaid';

    mermaid.initialize({
      startOnLoad: false,
      theme: 'dark',
      themeVariables: {
        primaryColor: '#1e293b',
        primaryTextColor: '#f8fafc',
        primaryBorderColor: '#38bdf8',
        lineColor: '#94a3b8',
        secondaryColor: '#334155',
        tertiaryColor: '#0f172a',
        background: 'transparent',
        mainBkg: '#1e293b',
        nodeBorder: '#38bdf8',
        clusterBkg: '#1e293b',
        titleColor: '#f8fafc',
        edgeLabelBackground: '#0f172a',
      },
      flowchart: {
        htmlLabels: true,
        curve: 'basis',
        padding: 20,
      },
    });

    async function renderMermaidBlock(pre: Element) {
      // Get the raw code text (strip any span styling from Shiki)
      const code = pre.textContent || '';

      // Create container with download button
      const container = document.createElement('div');
      container.className = 'mermaid-diagram';

      // Store raw code for download
      (container as HTMLElement).dataset.mermaidSource = code.trim();

      try {
        const { svg } = await mermaid.render(`mermaid-${Math.random().toString(36).slice(2)}`, code.trim());
        container.innerHTML = `
          <div class="mermaid-wrapper">
            ${svg}
            <button class="mermaid-download" title="Copy Mermaid source">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            </button>
          </div>
        `;
        pre.replaceWith(container);

        // Wire up the download button for this diagram
        const btn = container.querySelector('.mermaid-download');
        btn?.addEventListener('click', (e) => {
          const source = (container as HTMLElement).dataset.mermaidSource || '';
          navigator.clipboard.writeText(source);

          // Visual feedback
          const button = e.currentTarget as HTMLElement;
          button.classList.add('copied');
          setTimeout(() => button.classList.remove('copied'), 1500);
        });
      } catch (e) {
        console.error('Mermaid render error:', e);
        // On error, keep original code block visible
      }
    }

    // Lazily render mermaid blocks only when they enter the viewport — a
    // meaningful perf win for presentations that show one slide at a time.
    function initMermaidLazyLoad() {
      // Astro/Shiki uses data-language attribute, not class
      const mermaidBlocks = document.querySelectorAll('pre[data-language="mermaid"]');
      if (mermaidBlocks.length === 0) return;

      // Fall back to eager rendering if IntersectionObserver is unavailable.
      if (typeof IntersectionObserver === 'undefined') {
        mermaidBlocks.forEach((pre) => { void renderMermaidBlock(pre); });
        return;
      }

      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              obs.unobserve(entry.target);
              void renderMermaidBlock(entry.target);
            }
          });
        },
        { rootMargin: '200px' }
      );

      mermaidBlocks.forEach((pre) => observer.observe(pre));
    }

    // Run on page load
    document.addEventListener('DOMContentLoaded', initMermaidLazyLoad);
  </script>
  <!-- Slide visibility transitions -->
  <script>
    const slides = document.querySelectorAll('.slide');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1 }
    );

    slides.forEach((slide) => {
      observer.observe(slide);
    });

    // Make first slide visible immediately
    slides[0]?.classList.add('visible');
  </script>

  <style is:global>
    html {
      scroll-snap-type: y mandatory;
    }
    .slide {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      opacity: 0;
      transition: opacity 200ms ease-out;
    }
    .slide.visible {
      opacity: 1;
    }
  </style>
</BaseLayout>
