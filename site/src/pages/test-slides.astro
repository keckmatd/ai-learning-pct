---
import SlideLayout from '../layouts/SlideLayout.astro';
import Slide from '../components/Slide.astro';
import SlideNav from '../components/SlideNav.astro';
import SlideControls from '../components/SlideControls.astro';
---

<SlideLayout title="Test Slides">
  <Slide id="slide-1" variant="title">
    <h1>AI-Powered Development</h1>
    <p class="subtitle">From browser AI to CLI builders</p>
  </Slide>

  <Slide id="slide-2" variant="content">
    <h2>Navigation Controls</h2>
    <ul>
      <li>Arrow Left/Right to navigate</li>
      <li>Space bar advances</li>
      <li>Home/End for first/last</li>
      <li>Press <span class="code-inline">P</span> for presenter notes</li>
    </ul>
  </Slide>

  <Slide id="slide-3" variant="split">
    <h2>Two-Column Layout</h2>
    <div class="columns">
      <div>
        <h3 class="text-fluid-xl font-semibold text-accent mb-4">Left Column</h3>
        <p class="text-text-secondary">Perfect for comparing concepts, showing before/after, or pairing text with images.</p>
      </div>
      <div>
        <h3 class="text-fluid-xl font-semibold text-accent mb-4">Right Column</h3>
        <p class="text-text-secondary">Each column adapts to content. On mobile, columns stack vertically.</p>
      </div>
    </div>
  </Slide>

  <Slide id="slide-4" variant="code">
    <h2>Code Example</h2>
    <pre><code set:text={`// SlideControls emits custom events
document.addEventListener('slidechange', (e) => {
  const { slide, total } = e.detail;
  console.log('Slide ' + slide + ' of ' + total);
});`} /></pre>
  </Slide>

  <SlideNav currentSlide={1} totalSlides={4} />
  <SlideControls />
</SlideLayout>

<script>
  // Update nav dynamically based on current slide
  document.addEventListener('slidechange', (e) => {
    const { slide, total } = e.detail;

    // Update progress bar
    const progress = total > 1 ? ((slide - 1) / (total - 1)) * 100 : 0;
    const progressBar = document.querySelector('.progress-bar');
    if (progressBar) {
      progressBar.style.width = progress + '%';
    }

    // Update counter
    const counter = document.querySelector('.slide-nav .font-mono');
    if (counter) {
      counter.textContent = slide + ' / ' + total;
    }

    // Update nav button visibility
    const prevBtn = document.querySelector('.nav-prev');
    const nextBtn = document.querySelector('.nav-next');

    if (prevBtn) {
      prevBtn.classList.toggle('invisible', slide <= 1);
      prevBtn.setAttribute('href', slide > 1 ? '#slide-' + (slide - 1) : '');
    }
    if (nextBtn) {
      nextBtn.classList.toggle('invisible', slide >= total);
      nextBtn.setAttribute('href', slide < total ? '#slide-' + (slide + 1) : '');
    }
  });
</script>
