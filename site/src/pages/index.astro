---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="AI Learning Workshop | PCT Cabinet">
  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="min-h-screen flex flex-col items-center justify-center px-6 py-12 relative overflow-hidden">
      <!-- Background gradient orbs -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/4 -left-32 w-96 h-96 bg-sky-500/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-sky-400/10 rounded-full blur-3xl"></div>
      </div>

      <div class="relative z-10 text-center max-w-4xl mx-auto">
        <p class="text-sky-400 font-medium mb-4 tracking-wide uppercase text-sm">PCT Cabinet Workshop</p>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
          <span class="gradient-text">From Browser to CLI</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-400 mb-8 max-w-2xl mx-auto">
          Transform your AI interactions. Learn CLI tools, harness systems, and build workflows that compound.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/ai-learning-pct/slides/" class="inline-flex items-center justify-center gap-2 bg-sky-500 hover:bg-sky-400 text-slate-900 font-semibold px-8 py-4 rounded-lg transition-colors duration-200">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Start Presentation
          </a>
          <a href="/ai-learning-pct/docs/" class="inline-flex items-center justify-center gap-2 border border-slate-600 hover:border-sky-400 text-white font-semibold px-8 py-4 rounded-lg transition-colors duration-200">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
            Documentation
          </a>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </section>

    <!-- What You'll Learn Section -->
    <section class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">What You'll Learn</h2>
        <p class="text-slate-400 text-center mb-16 max-w-2xl mx-auto">
          From understanding how AI works to building your own automated workflows
        </p>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- Card 1: Core Concepts -->
          <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-8 hover:border-sky-400/50 transition-colors duration-300">
            <div class="w-14 h-14 bg-sky-500/10 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-3">Core Concepts</h3>
            <p class="text-slate-400 leading-relaxed">
              Tokens, context windows, RAG, and MCP. Understand how AI actually works under the hood.
            </p>
          </div>

          <!-- Card 2: CLI Tools -->
          <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-8 hover:border-sky-400/50 transition-colors duration-300">
            <div class="w-14 h-14 bg-sky-500/10 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-3">CLI Tools</h3>
            <p class="text-slate-400 leading-relaxed">
              Browser vs CLI differences, best practices, and the harness system that amplifies your workflow.
            </p>
          </div>

          <!-- Card 3: Hands-On Practice -->
          <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-8 hover:border-sky-400/50 transition-colors duration-300">
            <div class="w-14 h-14 bg-sky-500/10 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-3">Hands-On Practice</h3>
            <p class="text-slate-400 leading-relaxed">
              Install tools, run exercises with templates, and build real workflows you can use tomorrow.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Session Agenda Section -->
    <section class="py-24 px-6 bg-slate-800/30">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Session Agenda</h2>
        <p class="text-slate-400 text-center mb-16">90 minutes that will change how you work with AI</p>

        <div class="space-y-6">
          <!-- Part 1 -->
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-20 text-right">
              <span class="text-sky-400 font-mono font-semibold">25 min</span>
            </div>
            <div class="flex-shrink-0 w-8 flex flex-col items-center">
              <div class="w-4 h-4 bg-sky-400 rounded-full"></div>
              <div class="w-0.5 h-full bg-slate-700 mt-2"></div>
            </div>
            <div class="pb-8">
              <h3 class="text-xl font-semibold mb-2">Part 1: Core Concepts</h3>
              <p class="text-slate-400">Tokens, context windows, RAG, and MCP. The foundation you need to use AI effectively.</p>
            </div>
          </div>

          <!-- Part 2 -->
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-20 text-right">
              <span class="text-sky-400 font-mono font-semibold">20 min</span>
            </div>
            <div class="flex-shrink-0 w-8 flex flex-col items-center">
              <div class="w-4 h-4 bg-sky-400 rounded-full"></div>
              <div class="w-0.5 h-full bg-slate-700 mt-2"></div>
            </div>
            <div class="pb-8">
              <h3 class="text-xl font-semibold mb-2">Part 2: CLI Differences</h3>
              <p class="text-slate-400">Browser vs CLI, best practices, and the harness system that amplifies your workflow.</p>
            </div>
          </div>

          <!-- Part 3 -->
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-20 text-right">
              <span class="text-sky-400 font-mono font-semibold">35 min</span>
            </div>
            <div class="flex-shrink-0 w-8 flex flex-col items-center">
              <div class="w-4 h-4 bg-sky-400 rounded-full"></div>
              <div class="w-0.5 h-full bg-slate-700 mt-2"></div>
            </div>
            <div class="pb-8">
              <h3 class="text-xl font-semibold mb-2">Part 3: Hands-On</h3>
              <p class="text-slate-400">Install tools, work through exercises with templates, build workflows you can use tomorrow.</p>
            </div>
          </div>

          <!-- Part 4 -->
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-20 text-right">
              <span class="text-sky-400 font-mono font-semibold">10 min</span>
            </div>
            <div class="flex-shrink-0 w-8 flex flex-col items-center">
              <div class="w-4 h-4 bg-sky-400 rounded-full"></div>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Part 4: Inspiration</h3>
              <p class="text-slate-400">What's next? Advanced patterns, community resources, and where to go from here.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Start Section -->
    <section class="py-24 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Get Started?</h2>
        <p class="text-slate-400 mb-12 max-w-2xl mx-auto">
          Jump into the presentation, browse the docs, or grab the CLI cheatsheet for quick reference.
        </p>

        <div class="grid sm:grid-cols-3 gap-6">
          <a href="/ai-learning-pct/slides/" class="group block bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-sky-400 transition-all duration-300">
            <div class="w-12 h-12 bg-sky-500/10 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:bg-sky-500/20 transition-colors">
              <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"></path>
              </svg>
            </div>
            <h3 class="font-semibold mb-2">Slides</h3>
            <p class="text-sm text-slate-400">Start the interactive presentation</p>
          </a>

          <a href="/ai-learning-pct/docs/" class="group block bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-sky-400 transition-all duration-300">
            <div class="w-12 h-12 bg-sky-500/10 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:bg-sky-500/20 transition-colors">
              <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <h3 class="font-semibold mb-2">Documentation</h3>
            <p class="text-sm text-slate-400">Browse the full docs</p>
          </a>

          <a href="/ai-learning-pct/docs/cheatsheets/cli-quick-reference/" class="group block bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-sky-400 transition-all duration-300">
            <div class="w-12 h-12 bg-sky-500/10 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:bg-sky-500/20 transition-colors">
              <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="font-semibold mb-2">CLI Cheatsheet</h3>
            <p class="text-sm text-slate-400">Quick command reference</p>
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-8 px-6 border-t border-slate-800">
      <div class="max-w-4xl mx-auto text-center text-slate-500 text-sm">
        <p>PCT Cabinet AI Learning Workshop</p>
      </div>
    </footer>
  </main>
</BaseLayout>
