---
interface SlideInfo {
  id: string;
  title: string;
  part: number;
  slideNumber: number;
}

interface Props {
  slides: SlideInfo[];
}

const { slides } = Astro.props;

const partNames: Record<number, string> = {
  1: 'Core Concepts',
  2: 'CLI Differences',
  3: 'Hands-On',
  4: 'Inspiration',
};

// Group slides by part
const slidesByPart = slides.reduce(
  (acc, slide) => {
    if (!acc[slide.part]) {
      acc[slide.part] = [];
    }
    acc[slide.part].push(slide);
    return acc;
  },
  {} as Record<number, SlideInfo[]>
);

const parts = Object.keys(slidesByPart)
  .map(Number)
  .sort((a, b) => a - b);
---

<div
  id="overview-grid"
  class="fixed inset-0 z-[100] bg-[var(--color-bg-primary)]/95 backdrop-blur-sm overflow-y-auto hidden"
  role="dialog"
  aria-label="Slide overview"
  aria-modal="true"
>
  <div class="min-h-full p-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8 max-w-7xl mx-auto">
      <h2 class="text-2xl font-bold text-white">Slide Overview</h2>
      <button
        id="overview-close"
        class="p-2 rounded-lg text-white/50 hover:text-white hover:bg-white/10 transition-colors"
        aria-label="Close overview"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Parts -->
    <div class="max-w-7xl mx-auto space-y-8">
      {parts.map((partNum) => (
        <div>
          <h3 class="text-lg font-semibold text-[var(--color-accent)] mb-4 flex items-center gap-3">
            <span class="px-2 py-0.5 bg-[var(--color-accent)]/20 rounded text-sm">Part {partNum}</span>
            <span class="text-white/70">{partNames[partNum] || `Part ${partNum}`}</span>
          </h3>
          <div class="overview-grid-cards grid gap-3">
            {slidesByPart[partNum].map((slide) => (
              <a
                href={`#${slide.id}`}
                class="slide-card group p-3 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 hover:border-[var(--color-accent)]/50 transition-all duration-200"
                data-slide-id={slide.id}
              >
                <div class="flex items-start gap-2 mb-1">
                  <span class="text-xs font-mono text-[var(--color-text-muted)] group-hover:text-[var(--color-accent)] transition-colors">
                    {slide.slideNumber}
                  </span>
                </div>
                <p class="text-sm text-[var(--color-text-secondary)] group-hover:text-white line-clamp-2 leading-tight">
                  {slide.title}
                </p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Keyboard hint -->
    <div class="fixed bottom-4 left-1/2 -translate-x-1/2 text-white/60 text-sm">
      Press <kbd class="px-1.5 py-0.5 bg-white/10 rounded text-xs font-mono">Esc</kbd> or <kbd class="px-1.5 py-0.5 bg-white/10 rounded text-xs font-mono">O</kbd> to close
    </div>
  </div>
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Responsive grid for overview cards */
  .overview-grid-cards {
    grid-template-columns: 1fr;
  }

  @media (min-width: 360px) {
    .overview-grid-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 640px) {
    .overview-grid-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 768px) {
    .overview-grid-cards {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .overview-grid-cards {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .overview-grid-cards {
      grid-template-columns: repeat(6, 1fr);
    }
  }
</style>

<script>
  const overviewGrid = document.getElementById('overview-grid');
  const closeButton = document.getElementById('overview-close');

  function showOverview() {
    if (overviewGrid) {
      overviewGrid.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      // Focus the close button for accessibility
      closeButton?.focus();
    }
  }

  function hideOverview() {
    if (overviewGrid) {
      overviewGrid.classList.add('hidden');
      document.body.style.overflow = '';
    }
  }

  function isOverviewVisible() {
    return overviewGrid && !overviewGrid.classList.contains('hidden');
  }

  // Close button click
  closeButton?.addEventListener('click', hideOverview);

  // Click outside to close (click on backdrop)
  overviewGrid?.addEventListener('click', (e) => {
    if (e.target === overviewGrid) {
      hideOverview();
    }
  });

  // Slide card clicks - navigate and close
  const slideCards = document.querySelectorAll('.slide-card');
  slideCards.forEach((card) => {
    card.addEventListener('click', (e) => {
      e.preventDefault();
      const slideId = (card as HTMLElement).dataset.slideId;
      if (slideId) {
        hideOverview();
        // Small delay to let the overlay close smoothly
        setTimeout(() => {
          const slide = document.getElementById(slideId);
          if (slide) {
            window.location.hash = slideId;
            slide.scrollIntoView({ behavior: 'smooth' });
            // Dispatch slidechange event
            const match = slideId.match(/^slide-(\d+)$/);
            if (match) {
              const slideNumber = parseInt(match[1], 10);
              document.dispatchEvent(
                new CustomEvent('slidechange', {
                  detail: { slide: slideNumber, total: document.querySelectorAll('.slide').length },
                })
              );
            }
          }
        }, 100);
      }
    });
  });

  // Expose functions globally for SlideControls to use
  (window as any).slideOverview = {
    show: showOverview,
    hide: hideOverview,
    toggle: () => (isOverviewVisible() ? hideOverview() : showOverview()),
    isVisible: isOverviewVisible,
  };

  // Listen for custom events from SlideControls
  document.addEventListener('overview:toggle', () => {
    if (isOverviewVisible()) {
      hideOverview();
    } else {
      showOverview();
    }
  });

  document.addEventListener('overview:close', hideOverview);
</script>
