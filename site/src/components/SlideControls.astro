---
// No props needed - purely client-side behavior
---

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slides = document.querySelectorAll('.slide');
    const totalSlides = slides.length;

    function getCurrentSlideIndex() {
      const hash = window.location.hash;
      if (!hash) return 0;
      const match = hash.match(/^#slide-(\d+)$/);
      if (match) {
        const index = parseInt(match[1], 10) - 1;
        return Math.max(0, Math.min(index, totalSlides - 1));
      }
      return 0;
    }

    function navigateToSlide(index) {
      if (index < 0 || index >= totalSlides) return;
      const slideId = `slide-${index + 1}`;
      const slide = document.getElementById(slideId);
      if (slide) {
        window.location.hash = slideId;
        slide.scrollIntoView({ behavior: 'smooth' });
        dispatchSlideChange(index + 1);
      }
    }

    function dispatchSlideChange(slideNumber) {
      const event = new CustomEvent('slidechange', {
        detail: { slide: slideNumber, total: totalSlides },
      });
      document.dispatchEvent(event);
    }

    document.addEventListener('keydown', (e) => {
      // Ignore if user is typing in an input
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) {
        return;
      }

      const currentIndex = getCurrentSlideIndex();

      // Check if overview is visible - if so, only handle Escape and O
      const overviewVisible = window.slideOverview?.isVisible?.();

      if (overviewVisible) {
        if (e.key === 'Escape' || e.key === 'o' || e.key === 'O') {
          e.preventDefault();
          document.dispatchEvent(new CustomEvent('overview:close'));
        }
        return;
      }

      switch (e.key) {
        case 'ArrowLeft':
        case 'ArrowUp':
          e.preventDefault();
          navigateToSlide(currentIndex - 1);
          break;
        case 'ArrowRight':
        case 'ArrowDown':
        case ' ':
          e.preventDefault();
          navigateToSlide(currentIndex + 1);
          break;
        case 'o':
        case 'O':
          e.preventDefault();
          document.dispatchEvent(new CustomEvent('overview:toggle'));
          break;
        case 'Escape':
          // Close overview if open (handled above), otherwise do nothing
          break;
        case 'Home':
          e.preventDefault();
          navigateToSlide(0);
          break;
        case 'End':
          e.preventDefault();
          navigateToSlide(totalSlides - 1);
          break;
      }
    });

    // Handle hash changes from nav buttons
    window.addEventListener('hashchange', () => {
      const index = getCurrentSlideIndex();
      dispatchSlideChange(index + 1);
    });

    // Initialize on load
    const initialIndex = getCurrentSlideIndex();
    if (initialIndex > 0) {
      const slide = document.getElementById(`slide-${initialIndex + 1}`);
      if (slide) slide.scrollIntoView();
    }
    dispatchSlideChange(initialIndex + 1);
  });
</script>
