---
interface Props {
  chart: string;
  class?: string;
}

const { chart, class: className = '' } = Astro.props;
---

<div class:list={['mermaid-container', className]} data-mermaid={chart}>
  <pre class="mermaid">{chart}</pre>
</div>

<style>
  .mermaid-container {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 1.5rem 0;
  }

  .mermaid-container :global(svg) {
    max-width: 100%;
    height: auto;
  }

  /* Dark theme overrides for mermaid */
  .mermaid-container :global(.node rect),
  .mermaid-container :global(.node polygon) {
    fill: var(--color-bg-secondary) !important;
    stroke: var(--color-accent) !important;
  }

  .mermaid-container :global(.node .label) {
    color: var(--color-text-primary) !important;
  }

  .mermaid-container :global(.edgeLabel) {
    background-color: var(--color-bg-primary) !important;
    color: var(--color-text-secondary) !important;
  }

  .mermaid-container :global(.edge-pattern-solid) {
    stroke: var(--color-text-muted) !important;
  }

  .mermaid-container :global(marker) {
    fill: var(--color-text-muted) !important;
  }
</style>

<script>
  import mermaid from 'mermaid';

  mermaid.initialize({
    startOnLoad: true,
    theme: 'dark',
    themeVariables: {
      primaryColor: '#1e293b',
      primaryTextColor: '#f8fafc',
      primaryBorderColor: '#38bdf8',
      lineColor: '#94a3b8',
      secondaryColor: '#334155',
      tertiaryColor: '#0f172a',
      background: '#0f172a',
      mainBkg: '#1e293b',
      nodeBorder: '#38bdf8',
      clusterBkg: '#1e293b',
      titleColor: '#f8fafc',
      edgeLabelBackground: '#0f172a',
    },
    flowchart: {
      htmlLabels: true,
      curve: 'basis',
    },
  });

  // Re-render on page navigation (for SPAs)
  document.addEventListener('astro:page-load', () => {
    mermaid.run();
  });
</script>
