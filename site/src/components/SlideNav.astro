---
interface Props {
  currentSlide: number;
  totalSlides: number;
}

const { currentSlide, totalSlides } = Astro.props;
const progress = totalSlides > 1 ? ((currentSlide - 1) / (totalSlides - 1)) * 100 : 0;
---

<nav class="slide-nav fixed inset-0 pointer-events-none z-50" aria-label="Slide navigation">
  <!-- Previous button -->
  <a
    href={currentSlide > 1 ? `#slide-${currentSlide - 1}` : undefined}
    class:list={[
      'nav-prev',
      'pointer-events-auto',
      'absolute left-4 top-1/2 -translate-y-1/2',
      'p-3 rounded-full',
      'text-white/60 hover:text-white/70 hover:bg-white/10',
      'transition-all duration-200',
      'focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-400',
      currentSlide <= 1 && 'opacity-0 pointer-events-none',
    ]}
    aria-label="Previous slide"
    {...(currentSlide <= 1 && { 'aria-disabled': 'true', tabindex: -1 })}
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </a>

  <!-- Next button -->
  <a
    href={currentSlide < totalSlides ? `#slide-${currentSlide + 1}` : undefined}
    class:list={[
      'nav-next',
      'pointer-events-auto',
      'absolute right-4 top-1/2 -translate-y-1/2',
      'p-3 rounded-full',
      'text-white/60 hover:text-white/70 hover:bg-white/10',
      'transition-all duration-200',
      'focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-400',
      currentSlide >= totalSlides && 'opacity-0 pointer-events-none',
    ]}
    aria-label="Next slide"
    {...(currentSlide >= totalSlides && { 'aria-disabled': 'true', tabindex: -1 })}
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>

  <!-- Progress bar -->
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-white/10">
    <div
      class="progress-bar h-full bg-[var(--color-accent)] transition-all duration-300"
      style={`width: ${progress}%`}
    />
  </div>

  <!-- Slide counter -->
  <div class="pointer-events-auto absolute bottom-4 right-4 text-white/60 text-sm font-mono" aria-live="polite">
    {currentSlide} / {totalSlides}
  </div>
</nav>
